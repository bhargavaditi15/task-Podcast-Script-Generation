# Copy this file to .env and fill in only the provider(s) you plan to use.
# Nothing here is required at import time -- the Streamlit sidebar / CLI flags
# let you pick a provider and paste a key at runtime instead. Env vars just
# pre-fill the key field so you don't have to paste it every run.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Only needed for the "Custom (OpenAI-compatible)" provider option,
# e.g. a local Ollama/vLLM/LM Studio server.
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_API_KEY=
